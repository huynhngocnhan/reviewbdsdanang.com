// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectCategory {
  SUN
  VIN
  OTHER
}

enum SectionType {
  OVERVIEW
  LOCATION
  GALLERY // Phối cảnh
  EXTENTION // tiện ích
  FLOORPLAN // mặt bằng
  PRICE
  PROGRESS
  FAQ
  CTA
  CUSTOM
}

enum AssetProvider {
  R2
}

enum AssetType {
  IMAGE
  VIDEO
  FILE
}

model Admin {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile       AdminProfile?
  refreshTokens AdminRefreshToken[]
  projects      Project[]           @relation("ProjectCreatedBy")
  reports       Report[]            @relation("ReportHandledBy")
}

model AdminRefreshToken {
  id      String @id @default(uuid())
  adminId String
  admin   Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  tokenHash String
  /// Hết hạn refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
}

model AdminProfile {
  id      String @id @default(uuid())
  adminId String @unique
  admin   Admin  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  fullName String
  /// Chức danh (vd: Chuyên viên tư vấn BĐS)
  title    String?
  /// Mô tả ngắn / slogan
  tagline  String?
  phone    String?
  /// Địa chỉ làm việc
  address  String?
  /// Giờ làm việc hiển thị công khai
  workHours String?

  /// Ảnh đại diện (tham chiếu sang Asset)
  avatarAssetId String?
  avatarAsset   Asset?  @relation("AdminAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  mediaLinks Json? @default("[]")

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Asset {
  id String @id @default(uuid())

  /// Nhà cung cấp lưu trữ (R2)
  provider AssetProvider @default(R2)
  /// Loại file (image/video/file)
  type     AssetType

  /// Key object trong R2 (vd: projects/{projectId}/gallery/{uuid}.webp)
  key String @unique
  /// URL public/CDN để render trực tiếp
  url String

  /// MIME type (image/jpeg, image/webp, application/pdf...)
  contentType String
  /// Kích thước (bytes)
  size        Int
  width  Int?
  height Int?
  /// Alt text SEO (tuỳ chọn)
  alt    String?

  createdAt DateTime @default(now())

  adminAvatarProfiles AdminProfile[] @relation("AdminAvatar")

  projectCoverOf Project[] @relation("ProjectCover")
  projectOgOf    Project[] @relation("ProjectOg")
}

model Project {
  id String @id @default(uuid())

  /// Slug dùng cho route SEO (vd: sun-symphony-residence-da-nang)
  slug String @unique

  /// Trạng thái dự án: nháp / đã publish / lưu trữ
  status ProjectStatus @default(DRAFT)

  /// Tên dự án (vd: Căn hộ Sun Symphony)
  title    String
  /// Tiêu đề phụ (vd: "Sở hữu lâu dài - view sông Hàn") (tuỳ chọn)
  subtitle String?

  shortDescription String
  /// Giới thiệu ngắn về dự án (matching mockup)
  intro String?

  longDescription String?

  /// Nhóm dự án để filter như hiện tại: SUN / VIN / OTHER
  category      ProjectCategory @default(OTHER)
  /// Tên chủ đầu tư (vd: Sun Group) - để hiển thị
  developerName String?

  /// Loại hình dự án (vd: Căn hộ, Biệt thự, Đất nền)
  projectType String?

  /// Thành phố (vd: Đà Nẵng)
  city     String?
  /// Quận/Huyện (vd: Sơn Trà)
  district String?
  /// Địa chỉ chi tiết
  address  String?

  /// Vị trí text (vd: "Trần Hưng Đạo, Sơn Trà, Đà Nẵng")
  locationText String?
  /// Mô tả vị trí
  locationDescription String?
  /// Ảnh vị trí (bản đồ vệ tinh, quy hoạch...)
  locationImage String?
  /// Google Maps embed URL
  mapEmbedUrl String?
  /// V2 - URL vị trí 360
  location360Url String?
  /// V2 - nhóm tiện ích theo phút di chuyển
  nearbyGroups Json?
  /// V2 - hạ tầng giao thông lân cận
  nearbyTrafficItems Json?

  /// Toạ độ bản đồ (tuỳ chọn)
  lat Decimal? @db.Decimal(10, 7)
  lng Decimal? @db.Decimal(10, 7)

  /// Giá từ (để sort/filter; tuỳ chọn vì nhiều dự án không công khai giá)
  priceFrom BigInt?
  /// Giá đến (nếu muốn hiển thị khoảng giá)
  priceTo   BigInt?
  /// Đơn vị giá (vd: "tỷ", "triệu/m2", "liên hệ") - tuỳ chọn
  priceUnit String?

  /// Pháp lý (vd: "Sở hữu lâu dài", "50 năm") - tuỳ chọn
  legal        String?
  /// Thời điểm bàn giao (vd: "2026", "Q4/2026") - tuỳ chọn
  handoverTime String?

  /// Tags nổi bật (vd: ["View sông", "Trung tâm", "Sổ hồng"]) - matching mockup
  highlights String[] @default([])

  /// [NEW] Có hiển thị dự án ở trang chủ hay không
  /// - Admin bật/tắt để tránh trang chủ hiển thị quá nhiều dự án
  showOnHome Boolean @default(false)

  /// [NEW] Thứ tự ưu tiên hiển thị trên trang chủ (số nhỏ lên trước)
  /// - Có thể để null nếu không cần ưu tiên
  homeOrder Int?

  /// [NEW] Đánh dấu là dự án nổi bật (hiển thị filter "Dự án nổi bật" ở trang chủ)
  isFeatured Boolean @default(false)

  /// [NEW] Cấu hình sticky menu theo anchor (overlay trái/phải, danh sách mục)
  stickyMenu Json?

  /// [NEW] Hero mini-form lấy SĐT + nhu cầu
  heroLeadForm Json?

  /// [NEW] Floating CTA mở rộng (ngoài phone/zalo mặc định)
  floatingCtas Json?

  /// [NEW] SEO head mở rộng + JSON-LD
  seoHead Json?

  /// Hero image cho section tổng quan
  heroImage String?

  /// Thông số kỹ thuật (vd: [{label, value}])
  specs Json?

  /// Ảnh cover dùng cho card/list (URL string)
  coverImage String?
  /// Ảnh cover dùng cho card/list (Asset reference)
  coverAssetId String?
  coverAsset   Asset?  @relation("ProjectCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  /// Ảnh OG cho chia sẻ mạng xã hội (tuỳ chọn)
  ogAssetId String?
  ogAsset   Asset?  @relation("ProjectOg", fields: [ogAssetId], references: [id], onDelete: SetNull)

  /// SEO title (nếu không set thì fallback = title)
  metaTitle       String?
  /// SEO description (nếu không set thì fallback = shortDescription)
  metaDescription String?

  /// Gallery images (vd: [{src, alt}])
  gallery Json?

  /// Tiện ích - mô tả
  extentionDescription String?
  /// Tiện ích - hình ảnh (vd: [{src, alt, title, description}])
  extentionImages Json?
  /// V2 - điểm đến/tiện ích kết nối
  extentionDestinations Json?

  /// Mặt bằng (legacy) (vd: [{description, floorPlanImage}])
  floorplans Json?

  /// [NEW] Lý do chọn mua (legacy JSON)
  reasonToBuy Json?
  /// V2 - tiêu đề section lý do chọn mua
  reasonToBuyTitle String?
  /// V2 - mô tả lý do chọn mua
  reasonToBuyDescription String?
  /// V2 - ảnh lý do chọn mua
  reasonToBuyImage String?
  /// V2 - alt ảnh lý do chọn mua
  reasonToBuyImageAlt String?

  /// [NEW] Chính sách bán hàng (legacy JSON)
  salesPolicy Json?
  /// V2 - chính sách bán hàng chuẩn theo UI hiện tại
  salePolicy Json?
  /// V2 - mô tả ngắn chính sách bán hàng
  salePolicyDes String?
  /// V2 - ảnh chính sách bán hàng
  salePolicyImg String?
  /// V2 - alt ảnh chính sách bán hàng
  salePolicyAlt String?
  /// V2 - danh sách mô tả chi tiết chính sách
  salePolicyDescriptionDetails Json?

  /// [NEW] Mặt bằng tổng quan (vd: [{src, alt, title}])
  floorplanMaster Json?

  /// [NEW] Mặt bằng tầng (vd: [{floor, images:[{src, alt}]}])
  floorplanByFloor Json?

  /// V2 - thiết kế căn hộ
  apartmentDesign Json?

  /// V2 - tiêu chuẩn bàn giao (vd: { des: "string", items: [{subtitle, title, des, imgUrl}] })
  handoverStandard Json?

  /// [NEW] Loại căn hộ (vd: [{name, area, description, images:[{src, alt}]}])
  unitLayouts Json?

  /// [NEW] Tiến độ dự án theo mốc thời gian (vd: [{label, date, description}])
  progressMilestones Json?

  /// [NEW] Tiến độ dự án - gallery (vd: [{src, alt, capturedAt}])
  progressGallery Json?

  /// [NEW] Tiến độ dự án - video YouTube URL (embed/watch)
  progressVideoUrl String?
  /// V2 - tiến độ dự án
  progress Json?
  /// V2 - mô tả tiến độ dự án
  progressDescription String?
  /// V2 - video tiến độ YouTube
  progressYoutubeUrl String?

  /// [NEW] FAQ (vd: [{question, answer}])
  faqs Json?

  /// [NEW] Pháp lý bổ sung (vd: [{title, value, fileUrl}])
  legalInfo Json?

  /// [NEW] Disclaimer quảng cáo
  advertisingDisclaimer String?

  /// Custom Sections (vd: [{customTitle, customDes, contents: [{contentTitle, contentDes, images}]}])
  customSections Json?

  /// Admin tạo dự án
  createdByAdminId String
  createdByAdmin   Admin  @relation("ProjectCreatedBy", fields: [createdByAdminId], references: [id])

  /// Danh sách sections linh động để render trang chi tiết
  sections ProjectSection[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([category])
  @@index([city, district])
  @@index([showOnHome, homeOrder]) // [NEW] hỗ trợ query trang chủ nhanh hơn
}

model ProjectSection {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Loại section (overview/location/gallery...)
  type  SectionType
  /// Tiêu đề section (tuỳ chọn; nhiều section có thể không cần)
  title String?

  /// Thứ tự hiển thị của section (kéo-thả)
  order   Int     @default(0)
  /// Bật/tắt section (admin có thể tắt mà không xoá)
  enabled Boolean @default(true)

  /// Payload dữ liệu theo type (JSON để linh động)
  /// Với EXTENTION, đề xuất schema:
  /// {
  ///   "extentionDescription": "string",
  ///   "images": [{ "assetId": "uuid", "title": "string", "description": "string" }]
  /// }
  /// Với FLOORPLAN, đề xuất schema:
  /// {
  ///   "description": "string",
  ///   "floorPlanImage": [{ "assetId": "uuid", "alt": "string" }]
  /// }
  data Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, order])
  @@index([projectId, type])
}

enum ReportStatus {
  NEW
  CONTACTED
  COMPLETED
  CANCELLED
}

model Report {
  id        String       @id @default(uuid())
  /// Họ và tên khách hàng
  fullname  String
  /// Email khách hàng (optional - nếu có sẽ nhận được auto-reply)
  email     String?
  /// Số điện thoại khách hàng
  phonenum  String
  /// Dự án khách hàng quan tâm
  project   String?
  /// Ghi chú/câu hỏi của khách
  note      String?
  /// Trạng thái xử lý
  status    ReportStatus @default(NEW)
  /// Admin xử lý (nếu có)
  handledByAdminId String?
  handledByAdmin   Admin?  @relation("ReportHandledBy", fields: [handledByAdminId], references: [id], onDelete: SetNull)
  /// Ghi chú của admin khi xử lý
  adminNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([handledByAdminId])
}
